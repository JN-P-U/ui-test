{
  "name": "ui-test-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/browser/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=ui-test",
    "build": "npm run build --workspace=ui-test",
    "test": "npm run test --workspace=@ui-test/react",
    "test:coverage": "npm run test:coverage --workspace=@ui-test/react",
    "test:e2e": "npm run test:e2e --workspace=ui-test",
    "test:all": "npm run test --workspace=@ui-test/react && npm run test:e2e --workspace=ui-test"
  }
}
