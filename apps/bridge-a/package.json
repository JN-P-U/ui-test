{
  "name": "bridge-a",
  "version": "1.0.0",
  "description": "폐쇄망 AI 개발 도우미 CLI",
  "main": "dist/index.js",
  "bin": {
    "aidd": "dist/index.js"
  },
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "bundle": "ncc build src/index.ts -o dist/bundle --minify",
    "pack:exe": "pkg dist/bundle/index.js --target node18-win-x64 --output dist/aidd.exe",
    "pack:all": "npm run bundle && npm run pack:exe"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vercel/ncc": "^0.38.1",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "pkg": {
    "targets": ["node18-win-x64"],
    "outputPath": "dist"
  }
}
